 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# SHAP Explainability Analysis\n",
    "\n",
    "Goals:\n",
    "- Global SHAP beeswarm plot (all features, all classes)\n",
    "- Per-prediction waterfall plot for key attack types\n",
    "- Validate that SHAP explanations are interpretable to a SOC analyst\n",
    "- Export example plots for README/demo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import shap\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from models.threat_classifier import ThreatClassifier\n",
    "from models.preprocessor import load as load_preprocessor\n",
    "from explainability.shap_explainer import SHAPExplainer\n",
    "\n",
    "shap.initjs()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load trained models (requires completed Phase 2 training)\n",
    "from pathlib import Path\n",
    "\n",
    "if Path('../models/xgb_classifier.ubj').exists():\n",
    "    clf = ThreatClassifier.load('../models/xgb_classifier.ubj')\n",
    "    pipeline = load_preprocessor('../models/preprocessor.joblib')\n",
    "    print('Models loaded successfully')\n",
    "else:\n",
    "    print('Models not trained yet. Run: python scripts/run_training.py')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate SHAP values for a sample of test data\n",
    "# (load from CICIDS or use synthetic sample)\n",
    "from data.sample.generate_sample import generate_sample\n",
    "from ingestion.normalizer import normalize_labels\n",
    "\n",
    "df = generate_sample(n_rows=200, seed=99)\n",
    "df.rename(columns={'Label': 'label'}, inplace=True)\n",
    "df = normalize_labels(df)\n",
    "\n",
    "feature_cols = [c for c in df.columns if c not in ('label', 'label_int')]\n",
    "X = df[feature_cols].values.astype(np.float32)\n",
    "\n",
    "if 'pipeline' in dir():\n",
    "    X_t = pipeline.transform(X)\n",
    "    explainer_obj = shap.TreeExplainer(clf.model, feature_perturbation='interventional')\n",
    "    shap_values = explainer_obj.shap_values(X_t[:50])  # first 50 rows\n",
    "    print(f'SHAP values type: {type(shap_values)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Waterfall plot for first prediction\n",
    "if 'shap_values' in dir():\n",
    "    feature_names = [f'feature_{i}' for i in range(X_t.shape[1])]\n",
    "    \n",
    "    if isinstance(shap_values, list):\n",
    "        sv = shap_values[0][0]\n",
    "        ev = explainer_obj.expected_value[0]\n",
    "    else:\n",
    "        sv = shap_values[0] if shap_values.ndim == 2 else shap_values[0, :, 0]\n",
    "        ev = float(explainer_obj.expected_value[0])\n",
    "    \n",
    "    explanation = shap.Explanation(\n",
    "        values=sv,\n",
    "        base_values=ev,\n",
    "        data=X_t[0],\n",
    "        feature_names=feature_names,\n",
    "    )\n",
    "    shap.plots.waterfall(explanation, max_display=15)"
   ]
  }
 ],
