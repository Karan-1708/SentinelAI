# Copy this file to .env and fill in your values
# .env is gitignored — never commit secrets

# ── Elasticsearch ──────────────────────────────────────────────────
ELASTIC_PASSWORD=changeme_elastic
KIBANA_PASSWORD=changeme_kibana
LOGSTASH_PASSWORD=changeme_logstash

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=sentinelai
DATABASE_URL=postgresql+asyncpg://sentinel:changeme_postgres@postgres:5432/sentinelai

# ── MinIO (MLflow artifact storage) ────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme_minio

# ── MLflow ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── API ────────────────────────────────────────────────────────────
API_SECRET_KEY=changeme_api_secret
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Model paths (inside Docker, shared volume) ─────────────────────
MODEL_PATH=/models/xgb_classifier.ubj
PREPROCESSOR_PATH=/models/preprocessor.joblib
ISOLATION_FOREST_PATH=/models/isolation_forest.joblib
