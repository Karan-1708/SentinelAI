# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.
#
# Generate strong secrets with:
#   openssl rand -hex 32
#
# Every REPLACE_ME_* below MUST be replaced. The API will refuse to start
# if any required secret is left at its placeholder value (see api/config.py).

# ── Elasticsearch ──────────────────────────────────────────────────
ELASTIC_PASSWORD=REPLACE_ME_openssl_rand_hex_32
KIBANA_PASSWORD=REPLACE_ME_openssl_rand_hex_32
LOGSTASH_PASSWORD=REPLACE_ME_openssl_rand_hex_32
ELASTICSEARCH_URL=https://elasticsearch:9200
ELASTICSEARCH_USER=elastic

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=REPLACE_ME_openssl_rand_hex_32
POSTGRES_DB=sentinelai
DATABASE_URL=postgresql+asyncpg://sentinel:REPLACE_ME_openssl_rand_hex_32@postgres:5432/sentinelai

# ── MinIO (MLflow artifact storage) ────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_ME_openssl_rand_hex_32
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=REPLACE_ME_openssl_rand_hex_32

# ── MLflow ─────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── API ────────────────────────────────────────────────────────────
# JWT signing key. Must be at least 32 bytes of high-entropy random data.
API_SECRET_KEY=REPLACE_ME_openssl_rand_hex_32
API_JWT_ISSUER=sentinelai
API_JWT_AUDIENCE=sentinelai-clients
API_ACCESS_TOKEN_MINUTES=30

# Comma-separated list of allowed CORS origins. Do not use "*".
CORS_ORIGINS=https://localhost,http://localhost:3000

# Environment: "development" | "staging" | "production".
# In production, the API refuses to boot if any secret still matches REPLACE_ME_*.
APP_ENV=development

# ── Model paths + integrity ────────────────────────────────────────
MODEL_PATH=/models/xgb_classifier.ubj
PREPROCESSOR_PATH=/models/preprocessor.joblib
ISOLATION_FOREST_PATH=/models/isolation_forest.joblib

# Path to a JSON file mapping model paths to their expected SHA-256 hashes.
# Written by the training pipeline; verified at API startup.
# Leave unset in development if you have not yet trained models.
MODEL_MANIFEST_PATH=/models/manifest.json
